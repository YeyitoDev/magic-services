# ==========================================
# Magic Chatbot v2 - Variables de Entorno
# ==========================================
# Copia este archivo como .env y completa los valores.
# NUNCA subas .env a control de versiones (Git).
# ==========================================

# ==========================================
# ENTORNO DE EJECUCIÓN
# ==========================================
# Opciones: development | production | testing
ENVIRONMENT=development

# Habilitar modo debug (true/false)
DEBUG=true

# Nivel de logging: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Nombre del proyecto
PROJECT_NAME=MagoChatbot

# Versión del proyecto
PROJECT_VERSION=2.2.0

# ==========================================
# TELEGRAM
# ==========================================
# Token del bot obtenido de @BotFather (REQUERIDO)
TELEGRAM_BOT_TOKEN=

# Username del bot sin el @ (ej: magopagos_bot)
TELEGRAM_BOT_USERNAME=magopagos_bot

# IDs de los validadores autorizados, separados por coma
# Estos usuarios recibirán las capturas de pago para validar/rechazar
TELEGRAM_VALIDATOR_IDS=1555885694,1707092473

# ID del grupo VIP de Telegram (número negativo para supergrupos)
TELEGRAM_VIP_GROUP_ID=-1002451833719

# URL del webhook para producción en PythonAnywhere (opcional)
# Ejemplo: https://tuusuario.pythonanywhere.com/webhook
TELEGRAM_WEBHOOK_URL=

# ==========================================
# TELEGRAM CLIENT (Telethon - Sync Members)
# ==========================================
# API ID de Telegram (my.telegram.org)
TELETHON_API_ID=

# API Hash de Telegram (my.telegram.org)
TELETHON_API_HASH=

# Número de teléfono asociado a la cuenta de Telegram
TELETHON_PHONE=

# ==========================================
# BASE DE DATOS (MySQL en AWS RDS)
# ==========================================
# Motor de base de datos (mysql+pymysql es para MySQL)
DB_ENGINE=mysql+pymysql

# Usuario de la base de datos (REQUERIDO)
DB_USER=

# Contraseña de la base de datos (REQUERIDO)
DB_PASSWORD=

# Host del servidor de base de datos (REQUERIDO)
DB_HOST=

# Puerto (3306 por defecto para MySQL)
DB_PORT=3306

# Nombre de la base de datos (REQUERIDO)
DB_NAME=

# Tamaño máximo del pool de conexiones
DB_POOL_SIZE=10

# Conexiones adicionales permitidas sobre el pool
DB_MAX_OVERFLOW=20

# Timeout en segundos para obtener una conexión del pool
DB_POOL_TIMEOUT=30

# ==========================================
# GOOGLE CLOUD
# ==========================================
# Ruta al archivo JSON de credenciales de servicio de Google Cloud
GOOGLE_CREDENTIALS_PATH=./credentials/magic-chatbottelegram-948350ae1b51.json

# ID de la Google Sheet principal (para registro de usuarios)
GOOGLE_SHEETS_ID=

# ID de la Google Sheet para usuarios WhatsApp (WSP)
GOOGLE_WSP_SPREADSHEET_ID=

# Nombre de la hoja de cálculo dentro del spreadsheet principal
GOOGLE_SHEETS_WORKSHEET_NAME=datos_usuarios

# ==========================================
# AWS (DynamoDB, S3)
# ==========================================
# AWS IAM Access Key ID
AWS_ACCESS_KEY_ID=

# AWS IAM Secret Access Key
AWS_SECRET_ACCESS_KEY=

# Región de AWS donde están los recursos
AWS_REGION=us-east-1

# Nombre de la tabla DynamoDB para sesiones de usuarios
AWS_DYNAMODB_TABLE=MAGIC-USER-SESSIONS-LOG

# ==========================================
# LINKS PROMOCIONALES - BETSAFE
# ==========================================
# Enlace de afiliado de BetSafe para la promoción de bienvenida
BETSAFE_PROMO_LINK=https://ofertas.betsafe.pe/es/oferta-de-bienvenida-deportes-affiliates?from=r2Gfcbr2vdPsrHMRgXyIsGNd7ZgqdRLk-AX3004666895&affcode=AX3004666895&utm_medium=MA_Affiliates&utm_source=10689544

# Texto del botón promocional de BetSafe
BETSAFE_BUTTON_TEXT=¡OBTÉN TUS 70 SOLES GRATIS!

# Link alternativo corto de BetSafe
BETSAFE_LINK=https://bit.ly/promobetsafemagic

# ==========================================
# FLASK API (para integraciones externas)
# ==========================================
# Host del servidor Flask
FLASK_HOST=0.0.0.0

# Puerto del servidor Flask
FLASK_PORT=5000

# Secret key para sesiones de Flask (CAMBIAR en producción)
FLASK_SECRET_KEY=change-me-please

# API Key para autenticación de endpoints externos
API_KEY=

# Versión de la API
API_VERSION=v1

# ==========================================
# JOBS PROGRAMADOS (Scheduler)
# ==========================================
# Intervalo en minutos para el job de recordatorios de compra
JOB_REMINDER_INTERVAL_MINUTES=10

# Hora del día para verificar suscripciones expiradas (formato 24h)
JOB_SUBSCRIPTION_CHECK_HOUR=20

# Hora del día para ejecutar limpieza general (formato 24h)
JOB_CLEANUP_HOUR=03

# Habilitar o deshabilitar jobs programados (true/false)
ENABLE_JOBS=true

# Zona horaria por defecto para todas las operaciones
TIMEZONE=America/Lima

# ==========================================
# LOGGING
# ==========================================
# Formato de salida de logs: json | text
LOG_FORMAT=text

# Directorio donde se guardan los archivos de log
LOG_FILE_PATH=./logs

# Tamaño máximo por archivo de log en bytes (10 MB por defecto)
LOG_FILE_MAX_SIZE=10485760

# Cantidad de archivos de backup a mantener
LOG_FILE_BACKUP_COUNT=10

# ==========================================
# PYTHONANYWHERE (Despliegue en Producción)
# ==========================================
# Dominio completo de tu cuenta en PythonAnywhere
# Ejemplo: tuusuario.pythonanywhere.com
PYTHONANYWHERE_DOMAIN=

# Nombre de usuario en PythonAnywhere
PYTHONANYWHERE_USERNAME=

# ==========================================
# SEGURIDAD
# ==========================================
# Hosts permitidos (separados por coma) para CORS/seguridad
ALLOWED_HOSTS=localhost,127.0.0.1

# Orígenes CORS permitidos (separados por coma)
CORS_ORIGINS=http://localhost:3000

# Secret para sesiones (CAMBIAR en producción)
SESSION_SECRET=

# ==========================================
# STREAMLINE DASHBOARD (opcional)
# ==========================================
# Puerto para el dashboard de Streamlit
STREAMLIT_PORT=8501
